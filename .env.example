# Variáveis de ambiente - Portal Rádio Cultura FM
# Configure no painel do Vercel (Settings > Environment Variables)

# YouTube Data API v3 - https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# (Opcional) API de notícias adicional - https://newsapi.org/register
NEWS_API_KEY=

# (Opcional) Unsplash Access Key - https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# (Opcional) NASA API Key - https://api.nasa.gov/ (use "DEMO_KEY" para testes)
NASA_API_KEY=

# Facebook Graph API - https://developers.facebook.com/
FACEBOOK_PAGE_ID=
FACEBOOK_ACCESS_TOKEN=

# (Opcional) Google Analytics
GA_TRACKING_ID=

# Configuração regional
WEATHER_LOCATION=Guaíra,SP
CACHE_DURATION_MINUTES=30
