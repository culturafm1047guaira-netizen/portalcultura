# Variáveis de ambiente - Portal Rádio Cultura FM
# Configure no painel do Vercel (Settings > Environment Variables)

# YouTube Data API v3 - https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# (Futuro) API de notícias adicional
NEWS_API_KEY=

# (Futuro) Google Analytics (opcional)
GA_TRACKING_ID=

# Configuração regional
WEATHER_LOCATION=Guaíra,SP
CACHE_DURATION_MINUTES=30