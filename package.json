{
  "name": "radio-cultura-portal",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "vercel dev",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPattern=tests/unit",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPattern=tests/integration",
    "test:e2e": "npx playwright test",
    "lint": "echo 'No linter configured'",
    "lint:fix": "echo 'No linter configured'"
  },
  "dependencies": {
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "transform": {},
    "moduleFileExtensions": ["js", "mjs"],
    "testMatch": ["**/tests/**/*.test.js"],
    "collectCoverageFrom": [
      "js/*.js",
      "api/*.js",
      "!js/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "verbose": true,
    "setupFilesAfterEnv": ["<rootDir>/tests/setup.js"]
  }
}